# ---- App ----
# Public base URL (used in emails, payment redirects, webhooks). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase (Postgres + Storage) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY. Never expose to the client. Bypasses RLS for writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Storage bucket name for uploaded art.
SUPABASE_STORAGE_BUCKET=art

# ---- Payments: Square ----
# https://developer.squareup.com/apps  (use sandbox values in dev)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# 'sandbox' or 'production'
SQUARE_ENVIRONMENT=sandbox
# Signature key from the webhook subscription, used to verify Square webhooks.
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ---- Payments: PayPal ----
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# 'sandbox' or 'live'
PAYPAL_ENVIRONMENT=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_ENVIRONMENT=sandbox

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM="GoldenPixel <hello@goldenpixel.co>"

# ---- Moderation (OpenAI omni-moderation) ----
# If unset, moderation is skipped (everything passes) so local dev isn't blocked.
OPENAI_API_KEY=

# ---- Admin + magic-link signing ----
# Long random string used to sign magic-link / admin tokens (HMAC).
TOKEN_SECRET=change-me-to-a-long-random-string
# Comma-separated admin emails allowed into /admin.
ADMIN_EMAILS=kamellokman.s@gmail.com

# ---- Cleanup job auth ----
# Bearer token required to hit the reservation-cleanup endpoint from a cron.
CLEANUP_SECRET=change-me
